# Database — consumed by docker-compose, Flyway, the API, and the seed loader.
POSTGRES_USER=impressions
POSTGRES_PASSWORD=impressions
POSTGRES_DB=impressions
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JDBC URL the API/seed use (host/port as seen from the app).
# In docker-compose the host becomes `postgres`; locally it's localhost.
DATABASE_URL=jdbc:postgresql://localhost:5432/impressions

# Source data for the seed loader.
SEED_IMPRESSIONS_CSV=assets/impressions.csv
SEED_STATES_GEOJSON=assets/map.json
